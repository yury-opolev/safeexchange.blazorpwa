# Local deploy secrets — copy to .env and fill in.
# .env is gitignored. Never commit it.
#
# The deploy-pwa.ps1 script reads this file to figure out where
# the built Blazor WASM bundle should be uploaded for a given
# environment.
#
# All values are operator-specific or environment-specific and
# must not land in git.

# HOSTING_TYPE_<ENV>
#   Which Azure service hosts the PWA static files for this
#   environment. Determines which branch of deploy-pwa.ps1 runs.
#
#   One of:
#     storage        — Azure Storage account with static-website
#                      ($web container) enabled, typically behind
#                      Azure Front Door or CDN.
#     staticwebapp   — Azure Static Web Apps.
#     appservice     — Azure App Service (Web App) with the PWA
#                      deployed as a zip.
#
#   Example:
#     HOSTING_TYPE_TEST=storage
#     HOSTING_TYPE_PRD=storage
HOSTING_TYPE_TEST=
HOSTING_TYPE_PRD=

# RESOURCE_GROUP_<ENV>
#   Azure resource group that owns the hosting resource below.
#
#   Example:
#     RESOURCE_GROUP_TEST=safeexchange-staging
#     RESOURCE_GROUP_PRD=safeexchange-backend
RESOURCE_GROUP_TEST=
RESOURCE_GROUP_PRD=

# ──────────────────────────────────────────────────────────────
# Hosting target — fill in the block that matches HOSTING_TYPE_*
# ──────────────────────────────────────────────────────────────

# storage: name of the storage account that has static-website
# enabled. The script uploads wwwroot/* into the $web container.
#
#   Example:
#     STORAGE_ACCOUNT_TEST=safeexchangestagingweb
#     STORAGE_ACCOUNT_PRD=safeexchangeprdweb
STORAGE_ACCOUNT_TEST=
STORAGE_ACCOUNT_PRD=

# STORAGE_ACCOUNT_ADMIN_<ENV>
#   Separate storage account hosting the SafeExchange.AdminPanel
#   static site. Read by deploy-adminpanel.ps1 only — the main PWA
#   continues to read STORAGE_ACCOUNT_<ENV> above. Storage-account
#   names are 3-24 chars, lowercase + digits only.
#
#   First-time setup (once per environment):
#     az storage account create --name <name> --resource-group <rg> \
#         --location <region> --sku Standard_LRS --kind StorageV2
#     az storage blob service-properties update --account-name <name> \
#         --static-website --index-document index.html \
#         --404-document index.html --auth-mode login
#
#   Example:
#     STORAGE_ACCOUNT_ADMIN_TEST=saexstagingadm
#     STORAGE_ACCOUNT_ADMIN_PRD=saexprdadm
STORAGE_ACCOUNT_ADMIN_TEST=
STORAGE_ACCOUNT_ADMIN_PRD=

# staticwebapp: name of the Azure Static Web App resource.
# Requires the SWA CLI (`npm install -g @azure/static-web-apps-cli`)
# and a deployment token for the environment.
#
#   Example:
#     STATIC_WEB_APP_TEST=safeexchange-staging-swa
#     STATIC_WEB_APP_PRD=safeexchange-prd-swa
STATIC_WEB_APP_TEST=
STATIC_WEB_APP_PRD=

# appservice: name of the App Service / Web App that hosts the PWA.
# The script builds a publish zip and uploads via `az webapp deploy`.
#
#   Example:
#     APP_SERVICE_TEST=safeexchange-staging-pwa
#     APP_SERVICE_PRD=safeexchange-prd-pwa
APP_SERVICE_TEST=
APP_SERVICE_PRD=

# ──────────────────────────────────────────────────────────────
# appsettings.json overrides (required, one set per environment)
# ──────────────────────────────────────────────────────────────
# After `dotnet publish`, deploy-pwa.ps1 overwrites specific keys
# in the published wwwroot/appsettings.json with the values below
# before uploading to $web. This keeps real prod identity + backend
# URLs out of git (source appsettings.json holds staging-dev
# defaults that work for `dotnet run`).
#
# APPSETTINGS_AUTHORITY_<ENV>
#   Full Entra ID authority URL including tenant GUID. Lands in
#   AzureAdB2C.Authority.
# APPSETTINGS_CLIENT_ID_<ENV>
#   Application (client) ID of the Entra app registration for the
#   environment. Lands in AzureAdB2C.ClientId.
# APPSETTINGS_BACKEND_<ENV>
#   Backend API base URL including trailing /api/. Lands in
#   BackendApi.BaseAddress.
# APPSETTINGS_SCOPE_<ENV>
#   OAuth2 scope to request for calls to the backend API. Lands as
#   the single entry in AccessTokenScopes.
#
#   Example:
#     APPSETTINGS_AUTHORITY_TEST=https://login.microsoftonline.com/<tenantGuid>
#     APPSETTINGS_CLIENT_ID_TEST=00000000-0000-0000-0000-000000000000
#     APPSETTINGS_BACKEND_TEST=https://safeexchange-staging.azurewebsites.net/api/
#     APPSETTINGS_SCOPE_TEST=api://<appIdUri>/user_impersonation
APPSETTINGS_AUTHORITY_TEST=
APPSETTINGS_CLIENT_ID_TEST=
APPSETTINGS_BACKEND_TEST=
APPSETTINGS_SCOPE_TEST=
APPSETTINGS_AUTHORITY_PRD=
APPSETTINGS_CLIENT_ID_PRD=
APPSETTINGS_BACKEND_PRD=
APPSETTINGS_SCOPE_PRD=

# ──────────────────────────────────────────────────────────────
# Optional: Azure Front Door cache purge
# ──────────────────────────────────────────────────────────────
# If the PWA is fronted by Azure Front Door, populate both
# values so the script can purge the cache after upload.
# Otherwise leave blank and the purge step is skipped.
#
# FRONT_DOOR_PROFILE_<ENV>
#   Name of the Front Door (Standard/Premium) profile resource.
# FRONT_DOOR_ENDPOINT_<ENV>
#   Name of the endpoint (afd endpoint, not the hostname).
# FRONT_DOOR_RG_<ENV>
#   Resource group that owns the Front Door profile. Optional —
#   defaults to RESOURCE_GROUP_<ENV> when unset. Only needed when
#   the AFD lives in a shared networking/DNS resource group
#   separate from the storage account.
#
#   Example:
#     FRONT_DOOR_PROFILE_TEST=safeexchange-afd
#     FRONT_DOOR_ENDPOINT_TEST=safeexchange-staging
#     FRONT_DOOR_RG_TEST=shared-dns-and-frontdoor
FRONT_DOOR_PROFILE_TEST=
FRONT_DOOR_ENDPOINT_TEST=
FRONT_DOOR_RG_TEST=
FRONT_DOOR_PROFILE_PRD=
FRONT_DOOR_ENDPOINT_PRD=
FRONT_DOOR_RG_PRD=

# ──────────────────────────────────────────────────────────────
# Optional: Azure subscription
# ──────────────────────────────────────────────────────────────
# If set, the script runs `az account set --subscription` before
# any deployment commands. Leave blank to use whatever subscription
# the current `az login` defaults to.
#
#   Example:
#     SUBSCRIPTION=00000000-0000-0000-0000-000000000000
SUBSCRIPTION=
