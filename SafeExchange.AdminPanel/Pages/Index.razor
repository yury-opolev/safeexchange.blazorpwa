@page "/"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<h2><i class="bi bi-speedometer2"></i> Dashboard</h2>
<p class="text-muted">Manage users, S2S applications, and search the audit log.</p>

<div class="row g-3 mt-2">
    <div class="col-12 col-md-6 col-xl-4">
        <a href="users" class="admin-card text-decoration-none">
            <i class="bi bi-people h2 mb-0" style="color: var(--admin-accent)"></i>
            <div class="grow">
                <div><strong>Users</strong></div>
                <div class="text-muted small">Browse, search, enable/disable</div>
            </div>
        </a>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <a href="applications" class="admin-card text-decoration-none">
            <i class="bi bi-robot h2 mb-0" style="color: var(--admin-accent)"></i>
            <div class="grow">
                <div><strong>Applications</strong></div>
                <div class="text-muted small">S2S apps — name or client-id search</div>
            </div>
        </a>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <a href="audit" class="admin-card text-decoration-none">
            <i class="bi bi-search h2 mb-0" style="color: var(--admin-accent)"></i>
            <div class="grow">
                <div><strong>Audit</strong></div>
                <div class="text-muted small">Find audit anchors by secret name — incl. deleted</div>
            </div>
        </a>
    </div>
</div>
