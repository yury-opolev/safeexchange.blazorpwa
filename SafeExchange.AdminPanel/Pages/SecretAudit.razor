@page "/audit/{AuditInstanceId}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using SafeExchange.Client.Common
@using SafeExchange.Client.Common.Model
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

@inject ApiClient apiClient
@inject NavigationManager NavManager

<div class="d-flex align-items-center mb-3">
    <button type="button" class="btn btn-outline-light" @onclick="this.GoBack">
        <i class="bi bi-arrow-left me-1"></i> Back to audit search
    </button>
    <h3 class="ms-3 mb-0">
        <i class="bi bi-clipboard-data"></i>
        Audit log — '@(this.response?.SecretObjectName ?? "…")'
        @if (this.response?.IsHistorical == true)
        {
            <span class="admin-pill historical ms-2"><i class="bi bi-archive"></i> historical</span>
        }
    </h3>
</div>

@if (this.loading)
{
    <div class="text-muted"><i class="spinner-border spinner-border-sm me-2"></i>Loading…</div>
}

@if (!string.IsNullOrEmpty(this.error))
{
    <div class="alert alert-warning">@this.error</div>
}

@if (this.response is not null)
{
    <div class="text-muted small mb-3">
        instance <code>@this.response.AuditInstanceId</code>
        · created @this.response.CreatedAt.ToString("yyyy-MM-dd HH:mm") by @this.response.CreatedBy
        @if (this.response.DeletedAt.HasValue)
        {
            <text> · deleted @this.response.DeletedAt.Value.ToString("yyyy-MM-dd HH:mm")</text>
        }
    </div>

    @if (!this.response.Page.AuditEnabled)
    {
        <div class="alert alert-secondary">
            Audit was not enabled when this secret was created. There is no audit log to display.
        </div>
    }
    else if (this.events.Count == 0)
    {
        <p class="text-muted">No events.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var ev in this.events)
            {
                var key = ev.SequenceNumber.ToString();
                var isOpen = this.expanded.Contains(key);
                <li class="list-group-item bg-transparent text-body border-light">
                    <div class="d-flex align-items-center flex-wrap gap-2" role="button"
                         @onclick="() => this.Toggle(key)">
                        <i class="bi @(isOpen ? "bi-chevron-down" : "bi-chevron-right")"></i>
                        <span class="text-muted small">@FormatTime(ev)</span>
                        <span class="admin-pill @PillClass(ev.EventType)">@ev.EventType</span>
                        <span class="text-truncate" style="max-width:200px">
                            @(string.IsNullOrEmpty(ev.Actor.SubjectName) ? ev.Actor.SubjectId : ev.Actor.SubjectName)
                        </span>
                        <span class="text-truncate flex-grow-1 text-muted">@Summary(ev)</span>
                    </div>
                    @if (isOpen)
                    {
                        <div class="mt-2 row gx-3">
                            <div class="col-md-8">
                                <div class="text-muted small">Payload</div>
                                <pre class="bg-body-tertiary p-2 mb-2"><code>@Pretty(ev.Payload)</code></pre>
                            </div>
                            <div class="col-md-4">
                                <dl class="row mb-0 small">
                                    <dt class="col-5">Sequence</dt>
                                    <dd class="col-7">
                                        @(ev.SequenceFrom.HasValue && ev.SequenceTo.HasValue
                                            ? $"{ev.SequenceFrom}–{ev.SequenceTo}"
                                            : ev.SequenceNumber.ToString())
                                    </dd>
                                    @if (!string.IsNullOrEmpty(ev.ContentId))
                                    {
                                        <dt class="col-5">Content</dt>
                                        <dd class="col-7"><code class="small">@ev.ContentId</code></dd>
                                    }
                                    @if (ev.ChunkIds is not null && ev.ChunkIds.Count > 0)
                                    {
                                        <dt class="col-5">Chunks</dt>
                                        <dd class="col-7">@ev.ChunkIds.Count</dd>
                                    }
                                    <dt class="col-5">Hash</dt>
                                    <dd class="col-7"><code class="small">@Short(ev.Hash)</code></dd>
                                    <dt class="col-5">Prev hash</dt>
                                    <dd class="col-7"><code class="small">@Short(ev.PrevHash)</code></dd>
                                </dl>
                            </div>
                        </div>
                    }
                </li>
            }
        </ul>

        @if (!string.IsNullOrEmpty(this.response.Page.NextContinuation))
        {
            <div class="admin-pager mt-3">
                <button class="btn btn-sm btn-outline-light" @onclick="this.LoadMoreAsync" disabled="@this.loading">
                    Load more
                </button>
            </div>
        }
    }
}

@code {
    [Parameter] public string AuditInstanceId { get; set; } = string.Empty;

    private AdminSecretAuditPageOutput? response;
    private readonly List<SecretAuditEventOutput> events = new();
    private readonly HashSet<string> expanded = new();
    private bool loading;
    private string? error;

    protected override Task OnInitializedAsync() => this.FetchAsync(reset: true);

    private async Task FetchAsync(bool reset)
    {
        this.loading = true;
        this.error = null;
        try
        {
            var continuation = reset ? null : this.response?.Page.NextContinuation;
            var resp = await this.apiClient.GetAuditInstanceAsync(this.AuditInstanceId, continuation);
            if ("ok".Equals(resp.Status))
            {
                this.response = resp.Result;
                if (reset)
                {
                    this.events.Clear();
                }

                if (resp.Result?.Page is not null)
                {
                    this.events.AddRange(resp.Result.Page.Events);
                }
            }
            else
            {
                this.error = resp.Error ?? resp.Status;
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        finally
        {
            this.loading = false;
        }
    }

    private Task LoadMoreAsync() => this.FetchAsync(reset: false);

    private void Toggle(string key)
    {
        if (!this.expanded.Add(key))
        {
            this.expanded.Remove(key);
        }
    }

    private void GoBack() => this.NavManager.NavigateTo("audit");

    private static string FormatTime(SecretAuditEventOutput ev)
        => (ev.FirstAt ?? ev.OccurredAt).ToString("yyyy-MM-dd HH:mm:ssZ");

    private static string Short(string h)
        => string.IsNullOrEmpty(h) ? string.Empty : (h.Length > 12 ? h.Substring(0, 12) + "…" : h);

    private static string Summary(SecretAuditEventOutput ev)
    {
        if (ev.ChunkIds is not null && ev.ChunkIds.Count > 0)
        {
            return $"{ev.ContentId} · {ev.ChunkIds.Count} chunks";
        }

        if (!string.IsNullOrEmpty(ev.ContentId))
        {
            return ev.ContentId!;
        }

        return string.Empty;
    }

    private static string Pretty(object? payload)
    {
        if (payload is null)
        {
            return "(none)";
        }

        try
        {
            return System.Text.Json.JsonSerializer.Serialize(payload,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return payload.ToString() ?? "(none)";
        }
    }

    // Reuse admin-pill classes for visual consistency with the search list.
    private static string PillClass(string eventType) => eventType switch
    {
        "SecretCreated" => "ok",
        "SecretDeleted" => "off",
        "ContentRead" or "ContentWritten" or "ContentCommitted" => "",
        "PermissionGranted" => "ok",
        "PermissionRevoked" => "off",
        "AccessRequested" or "AccessRequestApproved" or "AccessRequestDenied" => "attn",
        _ => "",
    };
}
