@page "/secrets"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiClient apiClient
@inject NavigationManager NavManager

<h3><i class="bi bi-file-earmark-lock"></i> Secrets</h3>

<div class="row g-2 mb-3 align-items-end">
    <div class="col-12 col-md-4">
        <div class="input-group">
            <span class="input-group-text admin-search"><i class="bi bi-search"></i></span>
            <input class="form-control admin-search" placeholder="Search by name…" @bind="this.q" @bind:event="oninput" @onkeyup="this.OnSearchKey" />
            <button class="btn btn-outline-light" @onclick="this.SearchAsync">Search</button>
        </div>
    </div>
    <div class="col-12 col-md-3">
        <select class="form-select" value="@this.sortValue" @onchange="this.OnSortChanged">
            <option value="lastAccessed_asc">Last accessed (oldest first)</option>
            <option value="lastAccessed_desc">Last accessed (newest first)</option>
            <option value="name_asc">Name</option>
            <option value="created_desc">Created (newest)</option>
        </select>
    </div>
    <div class="col-12 col-md-3">
        <input type="date" class="form-control" value="@this.AccessedBeforeValue" @onchange="this.OnAccessedBeforeChanged" />
    </div>
</div>

@if (this.loading) { <div class="text-muted"><i class="spinner-border spinner-border-sm"></i> Loading…</div> }
@if (!string.IsNullOrEmpty(this.error)) { <div class="alert alert-warning">@this.error</div> }

@if (this.page is not null)
{
    @foreach (var s in this.page.Items)
    {
        <div class="admin-card">
            <div class="grow">
                <div><strong>@s.ObjectName</strong></div>
                <div class="text-muted small">last accessed @s.LastAccessedAt.ToString("yyyy-MM-dd")</div>
            </div>
            <button class="btn btn-sm btn-outline-primary"
                    @onclick="@(() => this.NavManager.NavigateTo($"secrets/{Uri.EscapeDataString(s.ObjectName)}"))"
                    title="View secret details">
                <i class="bi bi-file-text"></i>&nbsp;Details
            </button>
        </div>
    }
    <div class="admin-pager">
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page - 1)" disabled="@(this.page.Page == 0)">Prev</button>
        <span>Page @(this.page.Page + 1) — @this.page.Total secret@(this.page.Total == 1 ? "" : "s") total</span>
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page + 1)" disabled="@(!this.page.HasMore)">Next</button>
    </div>
}

@code {
    private PaginatedResult<SecretAdminOverview>? page;
    private string q = string.Empty;
    private string sortValue = "lastAccessed_asc";
    private string sortBy = "lastAccessed";
    private string sortDir = "asc";
    private DateTime? accessedBefore;
    private bool loading;
    private string? error;

    private string AccessedBeforeValue
        => this.accessedBefore.HasValue ? this.accessedBefore.Value.ToString("yyyy-MM-dd") : string.Empty;

    protected override Task OnInitializedAsync() => this.GoAsync(0);

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await this.SearchAsync();
        }
    }

    private Task SearchAsync() => this.GoAsync(0);

    private async Task OnSortChanged(ChangeEventArgs e)
    {
        this.sortValue = e.Value?.ToString() ?? "lastAccessed_asc";
        var parts = this.sortValue.Split('_');
        this.sortBy = parts.Length > 0 ? parts[0] : "lastAccessed";
        this.sortDir = parts.Length > 1 ? parts[1] : "asc";
        await this.GoAsync(0);
    }

    private async Task OnAccessedBeforeChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrEmpty(raw))
        {
            this.accessedBefore = null;
        }
        else if (DateTime.TryParse(raw, out var parsed))
        {
            this.accessedBefore = parsed;
        }

        await this.GoAsync(0);
    }

    private async Task GoAsync(int p)
    {
        this.loading = true;
        this.error = null;
        try
        {
            var resp = await this.apiClient.ListSecretsAsync(
                this.q, p, 20, this.sortBy, this.sortDir, this.accessedBefore);
            if ("ok".Equals(resp.Status))
            {
                this.page = resp.Result;
            }
            else
            {
                this.error = resp.Error ?? resp.Status;
            }
        }
        finally
        {
            this.loading = false;
        }
    }
}
