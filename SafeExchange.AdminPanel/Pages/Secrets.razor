@page "/secrets"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiClient apiClient
@inject NavigationManager NavManager

<h3><i class="bi bi-file-earmark-lock"></i> Secrets</h3>

<div class="row g-3 mb-3 align-items-end">
    <div class="col-12 col-md-5">
        <label class="form-label small text-muted mb-1">Filter by name</label>
        <div class="input-group">
            <span class="input-group-text admin-search"><i class="bi bi-search"></i></span>
            <input class="form-control admin-search" placeholder="secret name contains…" @bind="this.q" @bind:event="oninput" @onkeyup="this.OnSearchKey" />
            <button class="btn btn-outline-light" @onclick="this.SearchAsync">Search</button>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <label class="form-label small text-muted mb-1">
            Last accessed before
            <i class="bi bi-info-circle" title="Shows only secrets not opened since this date — i.e. stale / cleanup candidates."></i>
        </label>
        <input type="date" class="form-control" value="@this.AccessedBeforeValue" @onchange="this.OnAccessedBeforeChanged" />
    </div>
</div>

@if (this.loading) { <div class="text-muted"><i class="spinner-border spinner-border-sm"></i> Loading…</div> }
@if (!string.IsNullOrEmpty(this.error)) { <div class="alert alert-warning">@this.error</div> }

@if (this.page is not null)
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th role="button" style="user-select:none" @onclick="@(() => this.SortByColumn("name"))">Name @this.SortCaret("name")</th>
                <th role="button" style="user-select:none" @onclick="@(() => this.SortByColumn("lastAccessed"))">Last accessed @this.SortCaret("lastAccessed")</th>
                <th role="button" style="user-select:none" @onclick="@(() => this.SortByColumn("created"))">Created @this.SortCaret("created")</th>
                <th class="text-end">@this.page.Total secret@(this.page.Total == 1 ? "" : "s")</th>
            </tr>
        </thead>
        <tbody>
            @if (this.page.Items.Count == 0)
            {
                <tr><td colspan="4" class="text-muted text-center py-3">No secrets match.</td></tr>
            }
            @foreach (var s in this.page.Items)
            {
                <tr>
                    <td><strong>@s.ObjectName</strong></td>
                    <td>@s.LastAccessedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-muted">@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary" @onclick="@(() => this.Open(s))" title="View secret details">
                            <i class="bi bi-file-text"></i>&nbsp;Details
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="admin-pager">
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page - 1)" disabled="@(this.page.Page == 0)">Prev</button>
        <span>Page @(this.page.Page + 1) — @this.page.Total secret@(this.page.Total == 1 ? "" : "s") total</span>
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page + 1)" disabled="@(!this.page.HasMore)">Next</button>
    </div>
}

@code {
    private PaginatedResult<SecretAdminOverview>? page;
    private string q = string.Empty;
    private string sortBy = "lastAccessed";
    private string sortDir = "asc";
    private DateTime? accessedBefore;
    private bool loading;
    private string? error;

    private string AccessedBeforeValue
        => this.accessedBefore.HasValue ? this.accessedBefore.Value.ToString("yyyy-MM-dd") : string.Empty;

    protected override Task OnInitializedAsync() => this.GoAsync(0);

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await this.SearchAsync();
        }
    }

    private Task SearchAsync() => this.GoAsync(0);

    // Clicking a column header sorts by it; clicking the active column flips the
    // direction. New columns get a sensible default (oldest-first for the date
    // columns — the stale-secret view — and A→Z for name).
    private async Task SortByColumn(string column)
    {
        if (this.sortBy == column)
        {
            this.sortDir = this.sortDir == "asc" ? "desc" : "asc";
        }
        else
        {
            this.sortBy = column;
            this.sortDir = column == "created" ? "desc" : "asc";
        }

        await this.GoAsync(0);
    }

    private MarkupString SortCaret(string column)
    {
        if (this.sortBy != column)
        {
            return (MarkupString)"<i class=\"bi bi-arrow-down-up text-secondary small ms-1\"></i>";
        }

        return (MarkupString)(this.sortDir == "asc"
            ? "<i class=\"bi bi-caret-up-fill text-info small ms-1\"></i>"
            : "<i class=\"bi bi-caret-down-fill text-info small ms-1\"></i>");
    }

    private void Open(SecretAdminOverview s)
        => this.NavManager.NavigateTo($"secrets/{Uri.EscapeDataString(s.ObjectName)}");

    private async Task OnAccessedBeforeChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrEmpty(raw))
        {
            this.accessedBefore = null;
        }
        else if (DateTime.TryParse(raw, out var parsed))
        {
            this.accessedBefore = parsed;
        }

        await this.GoAsync(0);
    }

    private async Task GoAsync(int p)
    {
        this.loading = true;
        this.error = null;
        try
        {
            var resp = await this.apiClient.ListSecretsAsync(
                this.q, p, 20, this.sortBy, this.sortDir, this.accessedBefore);
            if ("ok".Equals(resp.Status))
            {
                this.page = resp.Result;
            }
            else
            {
                this.error = resp.Error ?? resp.Status;
            }
        }
        finally
        {
            this.loading = false;
        }
    }
}
