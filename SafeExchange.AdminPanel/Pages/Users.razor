@page "/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiClient apiClient
@inject NavigationManager NavManager

<h3><i class="bi bi-people"></i> Users</h3>

<div class="input-group mb-3">
    <span class="input-group-text admin-search"><i class="bi bi-search"></i></span>
    <input class="form-control admin-search" placeholder="Search by UPN or display name…" @bind="this.q" @bind:event="oninput" @onkeyup="this.OnSearchKey" />
    <button class="btn btn-outline-light" @onclick="this.SearchAsync">Search</button>
</div>

<div class="input-group mb-3">
    <span class="input-group-text admin-search"><i class="bi bi-fingerprint"></i></span>
    <input class="form-control admin-search" placeholder="Find user by telemetry id (32 hex)…" @bind="this.tid" @bind:event="oninput" @onkeyup="this.OnTidKey" />
    <button class="btn btn-outline-light" @onclick="this.LookupByTelemetryIdAsync">Look up</button>
</div>
@if (!string.IsNullOrEmpty(this.tidError)) { <div class="alert alert-warning">@this.tidError</div> }

@if (this.loading) { <div class="text-muted"><i class="spinner-border spinner-border-sm"></i> Loading…</div> }
@if (!string.IsNullOrEmpty(this.error)) { <div class="alert alert-warning">@this.error</div> }

@if (this.page is not null)
{
    @foreach (var u in this.page.Items)
    {
        <div class="admin-card">
            <div class="grow">
                <div><strong>@u.AadUpn</strong></div>
                <div class="text-muted small">@u.DisplayName</div>
            </div>
            <span class="admin-pill @(u.Enabled ? "ok" : "off")">@(u.Enabled ? "enabled" : "disabled")</span>
            <button class="btn btn-sm btn-outline-primary"
                    @onclick="() => this.Manage(u)"
                    title="Manage user">
                <i class="bi bi-pencil-square"></i>&nbsp;Manage
            </button>
        </div>
    }
    <div class="admin-pager">
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page - 1)" disabled="@(this.page.Page == 0)">Prev</button>
        <span>Page @(this.page.Page + 1) — @this.page.Total user@(this.page.Total == 1 ? "" : "s") total</span>
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page + 1)" disabled="@(!this.page.HasMore)">Next</button>
    </div>
}

@code {
    private PaginatedResult<UserOverview>? page;
    private string q = string.Empty;
    private bool loading;
    private string? error;
    private string tid = string.Empty;
    private string? tidError;
    private static readonly System.Text.RegularExpressions.Regex TidPattern =
        new("^[0-9a-f]{32}$", System.Text.RegularExpressions.RegexOptions.Compiled);

    protected override Task OnInitializedAsync() => this.GoAsync(0);

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await this.SearchAsync();
        }
    }

    private Task SearchAsync() => this.GoAsync(0);

    private async Task OnTidKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await this.LookupByTelemetryIdAsync();
        }
    }

    private async Task LookupByTelemetryIdAsync()
    {
        this.tidError = null;
        var id = (this.tid ?? string.Empty).Trim().ToLowerInvariant();
        if (!TidPattern.IsMatch(id))
        {
            this.tidError = "Enter a 32-character hex telemetry id.";
            return;
        }

        var resp = await this.apiClient.FindUserByTelemetryIdAsync(id);
        if ("ok".Equals(resp.Status) && resp.Result is not null)
        {
            this.NavManager.NavigateTo($"users/{Uri.EscapeDataString(resp.Result.AadUpn)}");
            return;
        }

        this.tidError = "No active user has that telemetry id. Ids older than ~28 days are not retained, so they can't be resolved.";
    }

    private void Manage(UserOverview u)
        => this.NavManager.NavigateTo($"users/{Uri.EscapeDataString(u.AadUpn)}");

    private async Task GoAsync(int p)
    {
        this.loading = true;
        this.error = null;
        try
        {
            var resp = await this.apiClient.ListUsersAsync(this.q, p);
            if ("ok".Equals(resp.Status))
            {
                this.page = resp.Result;
            }
            else
            {
                this.error = resp.Error ?? resp.Status;
            }
        }
        finally
        {
            this.loading = false;
        }
    }
}
