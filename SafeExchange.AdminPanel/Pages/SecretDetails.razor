@page "/secrets/{Name}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using SafeExchange.Client.Common
@using SafeExchange.Client.Common.Model
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

@inject ApiClient apiClient
@inject NavigationManager NavManager

<div class="d-flex align-items-center mb-3">
    <button type="button" class="btn btn-outline-light" @onclick="this.GoToList">
        <i class="bi bi-arrow-left me-1"></i> Back to secrets
    </button>
    <h3 class="ms-3 mb-0">
        <i class="bi bi-file-earmark-lock"></i>
        @(this.detail?.ObjectName ?? this.Name)
    </h3>
    @if (this.detail is not null)
    {
        @if (this.detail.ExpiresAt.HasValue)
        {
            <span class="admin-pill attn ms-3">expires @this.detail.ExpiresAt.Value.ToString("yyyy-MM-dd")</span>
        }
        else if (this.detail.IdleDeleteAt.HasValue)
        {
            <span class="admin-pill attn ms-3">idle-delete @this.detail.IdleDeleteAt.Value.ToString("yyyy-MM-dd")</span>
        }
        else
        {
            <span class="admin-pill ok ms-3">active</span>
        }
    }
</div>

@if (this.loading) { <div class="text-muted"><i class="spinner-border spinner-border-sm me-2"></i>Loading…</div> }
@if (!string.IsNullOrEmpty(this.error)) { <div class="alert alert-warning">@this.error</div> }

@if (this.detail is not null)
{
    <div class="admin-card flex-column align-items-stretch">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9"><code>@this.detail.ObjectName</code></dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@this.detail.CreatedAt.ToString("u") · by @this.detail.CreatedBy</dd>

            <dt class="col-sm-3">Last modified</dt>
            <dd class="col-sm-9">@this.detail.ModifiedAt.ToString("u") · by @this.detail.ModifiedBy</dd>

            <dt class="col-sm-3">Last accessed</dt>
            <dd class="col-sm-9">@this.detail.LastAccessedAt.ToString("u")</dd>

            <dt class="col-sm-3">Expires</dt>
            <dd class="col-sm-9">@(this.detail.ExpiresAt.HasValue ? this.detail.ExpiresAt.Value.ToString("u") : "—")</dd>

            <dt class="col-sm-3">Idle deletion</dt>
            <dd class="col-sm-9">@(this.detail.IdleDeleteAt.HasValue ? this.detail.IdleDeleteAt.Value.ToString("u") : "—")</dd>

            <dt class="col-sm-3">Attachments</dt>
            <dd class="col-sm-9">@this.detail.AttachmentCount</dd>

            <dt class="col-sm-3">Tags</dt>
            <dd class="col-sm-9">
                @if (this.detail.Tags is { Length: > 0 })
                {
                    @foreach (var tag in this.detail.Tags)
                    {
                        <span class="badge bg-secondary me-1">@tag</span>
                    }
                }
                else
                {
                    <span>—</span>
                }
            </dd>

            <dt class="col-sm-3">Audit</dt>
            <dd class="col-sm-9">@(this.detail.AuditEnabled ? "enabled" : "disabled")</dd>

            <dt class="col-sm-3">Keep in storage</dt>
            <dd class="col-sm-9">@(this.detail.KeepInStorage ? "yes" : "no")</dd>
        </dl>
    </div>

    <h5 class="mt-4">Who has access</h5>

    @if (this.access is { Count: > 0 })
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Subject</th>
                    <th>Type</th>
                    <th>Read</th>
                    <th>Write</th>
                    <th>Grant</th>
                    <th>Revoke</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in this.access)
                {
                    <tr>
                        <td>@item.SubjectName</td>
                        <td>@item.SubjectType</td>
                        <td>@(item.CanRead ? "✓" : "—")</td>
                        <td>@(item.CanWrite ? "✓" : "—")</td>
                        <td>@(item.CanGrantAccess ? "✓" : "—")</td>
                        <td>@(item.CanRevokeAccess ? "✓" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else if (this.access is not null)
    {
        <p class="text-muted">No access entries.</p>
    }

    <p class="text-muted small mt-3 fst-italic">
        Secret content is never retrievable here — metadata and access only.
    </p>
}

@code {
    [Parameter] public string Name { get; set; } = string.Empty;

    private SecretAdminDetail? detail;
    private List<SecretAccessItem>? access;
    private bool loading;
    private string? error;

    protected override Task OnInitializedAsync() => this.FetchAsync();

    private async Task FetchAsync()
    {
        this.loading = true;
        this.error = null;
        try
        {
            var detailResp = await this.apiClient.GetSecretDetailAsync(this.Name);
            if ("ok".Equals(detailResp.Status))
            {
                this.detail = detailResp.Result;
            }
            else
            {
                this.error = detailResp.Error ?? detailResp.Status;
                return;
            }

            var accessResp = await this.apiClient.GetSecretAccessAsync(this.Name);
            if ("ok".Equals(accessResp.Status))
            {
                this.access = accessResp.Result;
            }
            else
            {
                this.error = accessResp.Error ?? accessResp.Status;
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        finally
        {
            this.loading = false;
        }
    }

    private void GoToList() => this.NavManager.NavigateTo("secrets");
}
