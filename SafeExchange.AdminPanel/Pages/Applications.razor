@page "/applications"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiClient apiClient

<h3><i class="bi bi-robot"></i> Applications</h3>

<div class="input-group mb-3">
    <span class="input-group-text admin-search"><i class="bi bi-search"></i></span>
    <input class="form-control admin-search" placeholder="Search by name or Entra client id (GUID)…" @bind="this.q" @bind:event="oninput" @onkeyup="this.OnSearchKey" />
    <button class="btn btn-outline-light" @onclick="this.SearchAsync">Search</button>
</div>

@if (this.loading) { <div class="text-muted"><i class="spinner-border spinner-border-sm"></i> Loading…</div> }
@if (!string.IsNullOrEmpty(this.error)) { <div class="alert alert-warning">@this.error</div> }

@if (this.page is not null)
{
    @foreach (var a in this.page.Items)
    {
        <div class="admin-card">
            <div class="grow">
                <div><strong>@a.DisplayName</strong></div>
                <div class="text-muted small">@a.AadClientId</div>
            </div>
            <span class="admin-pill @(a.Enabled ? "ok" : "off")">@(a.Enabled ? "enabled" : "disabled")</span>
            @if (a.OwnersAttentionRequired)
            {
                <span class="admin-pill attn" title="App has fewer than 2 owners — needs attention">
                    <i class="bi bi-exclamation-triangle"></i> attn (@a.OwnerCount owners)
                </span>
            }
            else
            {
                <span class="text-muted small">@a.OwnerCount owners</span>
            }
            <button class="btn btn-sm @(a.Enabled ? "btn-outline-warning" : "btn-outline-success")"
                    disabled="@this.toggling.Contains(a.DisplayName)"
                    @onclick="() => this.ToggleAsync(a)">
                @(a.Enabled ? "Disable" : "Enable")
            </button>
        </div>
    }
    <div class="admin-pager">
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page - 1)" disabled="@(this.page.Page == 0)">Prev</button>
        <span>Page @(this.page.Page + 1) — @this.page.Total app@(this.page.Total == 1 ? "" : "s") total</span>
        <button class="btn btn-sm btn-outline-light" @onclick="() => this.GoAsync(this.page.Page + 1)" disabled="@(!this.page.HasMore)">Next</button>
    </div>
}

@code {
    private PaginatedResult<ApplicationAdminOverview>? page;
    private string q = string.Empty;
    private bool loading;
    private string? error;
    private readonly HashSet<string> toggling = new();

    protected override Task OnInitializedAsync() => this.GoAsync(0);

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await this.SearchAsync();
    }

    private Task SearchAsync() => this.GoAsync(0);

    private async Task GoAsync(int p)
    {
        this.loading = true; this.error = null;
        try
        {
            var resp = await this.apiClient.ListApplicationsAsync(this.q, p);
            if ("ok".Equals(resp.Status)) { this.page = resp.Result; }
            else { this.error = resp.Error ?? resp.Status; }
        }
        finally { this.loading = false; }
    }

    private async Task ToggleAsync(ApplicationAdminOverview a)
    {
        this.toggling.Add(a.DisplayName);
        try
        {
            var resp = await this.apiClient.SetApplicationEnabledAsync(a.DisplayName, !a.Enabled);
            if ("ok".Equals(resp.Status)) { a.Enabled = !a.Enabled; }
            else { this.error = resp.Error ?? resp.Status; }
        }
        finally { this.toggling.Remove(a.DisplayName); }
    }
}
