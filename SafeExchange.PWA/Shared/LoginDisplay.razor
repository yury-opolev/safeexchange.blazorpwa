@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using SafeExchange.Client.Web.Components
@using SafeExchange.Client.Web.Components.Classes.Model
@using SafeExchange.Client.Web.Components.Helpers
@using System.Net.Http.Json
@using System.Security.Claims

@inject NavigationManager Navigation
@inject IOptionsSnapshot<RemoteAuthenticationOptions<ApiAuthorizationProviderOptions>> OptionsSnapshot
@inject ClipboardService Clipboard
@inject TelemetryService Telemetry
@inject ColorThemeHelper ColorThemeHelperInstance
@inject TooltipsInitializer TooltipsInitializerInstance
@inject HttpClient Http
@inject IJSRuntime JS

@implements IDisposable

<AuthorizeView>
    <Authorized>
        <a class="nav-link login-link" href="" @onclick:preventDefault id="userInfoDropdown"
           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-haspopup="true" aria-expanded="false"
           aria-label="Account menu">
            <i class="bi bi-person-circle"></i>
        </a>
        <div class="dropdown-menu dropdown-menu-end login-menu" aria-labelledby="userInfoDropdown">
            <div class="px-3 py-2">
                <div class="fw-semibold text-truncate">@context.User.Identity?.Name</div>
                @{ var upn = TokenHandler.GetName(context.User); }
                @if (!string.IsNullOrEmpty(upn) && !string.Equals(upn, context.User.Identity?.Name, StringComparison.OrdinalIgnoreCase))
                {
                    <small class="text-muted text-truncate d-block">@upn</small>
                }
            </div>
            <div class="dropdown-divider"></div>

            <div class="px-3 py-2">
                <div class="small text-muted mb-1">Theme</div>
                <div class="btn-group btn-group-sm w-100" role="group" aria-label="Theme">
                    <input type="radio" class="btn-check" name="login-theme" id="login-theme-auto"
                           checked="@(this.currentTheme == ColorTheme.Auto)"
                           @onchange="@(_ => this.OnThemeChangedAsync(ColorTheme.Auto))" />
                    <label class="btn btn-outline-secondary" for="login-theme-auto">
                        <i class="bi bi-circle-half"></i> Auto
                    </label>
                    <input type="radio" class="btn-check" name="login-theme" id="login-theme-dark"
                           checked="@(this.currentTheme == ColorTheme.Dark)"
                           @onchange="@(_ => this.OnThemeChangedAsync(ColorTheme.Dark))" />
                    <label class="btn btn-outline-secondary" for="login-theme-dark">
                        <i class="bi bi-moon-stars"></i> Dark
                    </label>
                    <input type="radio" class="btn-check" name="login-theme" id="login-theme-light"
                           checked="@(this.currentTheme == ColorTheme.Light)"
                           @onchange="@(_ => this.OnThemeChangedAsync(ColorTheme.Light))" />
                    <label class="btn btn-outline-secondary" for="login-theme-light">
                        <i class="bi bi-sun"></i> Light
                    </label>
                </div>
            </div>

            <div class="px-3 py-2">
                <div class="small text-muted mb-1">Accent</div>
                <div class="btn-group btn-group-sm w-100" role="group" aria-label="Accent">
                    <input type="radio" class="btn-check" name="login-accent" id="login-accent-mono"
                           checked="@(this.currentAccent == "mono")"
                           @onchange="@(_ => this.OnAccentChangedAsync("mono"))" />
                    <label class="btn btn-outline-secondary" for="login-accent-mono">
                        <i class="bi bi-circle-half me-1"></i>Mono
                    </label>
                    <input type="radio" class="btn-check" name="login-accent" id="login-accent-vivid"
                           checked="@(this.currentAccent == "vivid")"
                           @onchange="@(_ => this.OnAccentChangedAsync("vivid"))" />
                    <label class="btn btn-outline-secondary" for="login-accent-vivid">
                        <i class="bi bi-circle-fill me-1 swatch-vivid"></i>Vivid
                    </label>
                    <input type="radio" class="btn-check" name="login-accent" id="login-accent-blue"
                           checked="@(this.currentAccent == "blue")"
                           @onchange="@(_ => this.OnAccentChangedAsync("blue"))" />
                    <label class="btn btn-outline-secondary" for="login-accent-blue">
                        <i class="bi bi-circle-fill me-1 swatch-blue"></i>Blue
                    </label>
                </div>
            </div>

            <div class="dropdown-divider"></div>

            <div class="px-3 pb-2">
                <button type="button" class="btn btn-link btn-sm w-100 text-start text-decoration-none px-0"
                        @onclick="this.GoToMyApps">
                    <i class="bi bi-robot me-2"></i>My S2S apps
                </button>
            </div>

            <div class="dropdown-divider"></div>

            <div class="px-3 py-2 d-flex align-items-center gap-2">
                <small class="text-muted text-nowrap">Session</small>
                @if (this.Telemetry.IsEnabled)
                {
                    <code @ref="this.sessionIdRef" class="flex-grow-1 text-truncate"
                          data-bs-toggle="tooltip" data-bs-placement="top" title="@this.Telemetry.SessionOperationId">@this.TruncatedSessionId</code>
                    <button @ref="this.copyButtonRef" type="button" class="btn btn-sm btn-outline-secondary"
                            data-bs-toggle="tooltip" data-bs-placement="top" title="Copy to clipboard"
                            aria-label="Copy session id" @onclick="this.CopySessionIdAsync">
                        <i class="bi bi-clipboard"></i>
                    </button>
                }
                else
                {
                    <small class="text-muted fst-italic flex-grow-1">…</small>
                }
            </div>

            @if (!string.IsNullOrEmpty(this.versionLabel))
            {
                <div class="dropdown-divider"></div>
                <div class="px-3 py-2 d-flex align-items-center gap-2">
                    <small class="text-muted text-nowrap">Version</small>
                    <span class="flex-grow-1 text-truncate" data-bs-toggle="tooltip" data-bs-placement="top" title="@this.versionTooltip">@this.versionLabel</span>
                </div>
            }

            <div class="dropdown-divider"></div>
            <div class="px-3 pb-2">
                <button class="btn btn-outline-secondary btn-sm w-100" @onclick="this.BeginSignOut">
                    <i class="bi bi-box-arrow-right me-1"></i> Sign out
                </button>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="nav-link login-link" href="" @onclick="this.BeginSignIn" @onclick:preventDefault
           aria-label="Sign in" title="Sign in">
            <i class="bi bi-person-slash"></i>
        </a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private const string AccentStorageKey = "client-accent";

    private ColorTheme currentTheme = ColorTheme.Auto;
    private string currentAccent = "blue";
    private string versionLabel = string.Empty;
    private string versionTooltip = string.Empty;

    private ElementReference copyButtonRef;
    private ElementReference sessionIdRef;

    private string TruncatedSessionId
    {
        get
        {
            var id = this.Telemetry.SessionOperationId;
            return id.Length > 8 ? $"{id.Substring(0, 8)}…" : id;
        }
    }

    protected override void OnInitialized()
    {
        this.Telemetry.StateChanged += this.OnTelemetryStateChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            this.currentTheme = await this.ColorThemeHelperInstance.GetPreferredThemeAsync();
            await this.ColorThemeHelperInstance.SetThemeAsync(this.currentTheme);
        }
        catch
        {
        }

        try
        {
            var stored = await this.JS.InvokeAsync<string?>("localStorage.getItem", AccentStorageKey);
            if (!string.IsNullOrEmpty(stored) && IsValidAccent(stored))
            {
                this.currentAccent = stored;
            }
            await this.ApplyAccentAsync(this.currentAccent);
        }
        catch
        {
        }

        try
        {
            var info = await this.Http.GetFromJsonAsync<VersionInfo>("version.json");
            if (info is { Version.Length: > 0 })
            {
                this.versionLabel = info.Version;
                this.versionTooltip = string.IsNullOrWhiteSpace(info.BuildDate)
                    ? this.versionLabel
                    : $"{this.versionLabel} · {info.BuildDate}";
            }
        }
        catch
        {
        }
    }

    private async Task OnAccentChangedAsync(string accent)
    {
        if (!IsValidAccent(accent) || string.Equals(this.currentAccent, accent, StringComparison.Ordinal))
        {
            return;
        }
        this.currentAccent = accent;
        try
        {
            await this.JS.InvokeVoidAsync("localStorage.setItem", AccentStorageKey, accent);
        }
        catch
        {
        }
        await this.ApplyAccentAsync(accent);
    }

    private async Task ApplyAccentAsync(string accent)
    {
        try
        {
            // Direct function-path interop; the PWA's CSP blocks eval, so the
            // earlier eval-based attempt silently failed.
            await this.JS.InvokeVoidAsync(
                "document.documentElement.setAttribute",
                "data-accent",
                accent);
        }
        catch
        {
        }
    }

    private static bool IsValidAccent(string accent)
        => accent == "mono" || accent == "vivid" || accent == "blue";

    public void Dispose()
    {
        this.Telemetry.StateChanged -= this.OnTelemetryStateChanged;
    }

    private void OnTelemetryStateChanged(object? sender, EventArgs e)
        => _ = this.InvokeAsync(this.StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (this.Telemetry.IsEnabled)
        {
            await this.TooltipsInitializerInstance.InitializeSingleTooltipAsync(this.copyButtonRef, "Copy to clipboard", "Copied");
            await this.TooltipsInitializerInstance.InitializePlainTooltipAsync(this.sessionIdRef);
        }

        if (!string.IsNullOrEmpty(this.versionLabel))
        {
            await this.TooltipsInitializerInstance.InitializeAllPlainTooltipsAsync();
        }
    }

    private async Task OnThemeChangedAsync(ColorTheme theme)
    {
        if (this.currentTheme == theme)
        {
            return;
        }
        this.currentTheme = theme;
        await this.ColorThemeHelperInstance.SetThemeAsync(theme);
    }

    private async Task CopySessionIdAsync()
    {
        try
        {
            await this.Clipboard.WriteTextAsync(this.Telemetry.SessionOperationId);
        }
        catch
        {
        }
    }

    private void BeginSignIn(MouseEventArgs args)
    {
        this.Navigation.NavigateToLogin(this.OptionsSnapshot.Get(Options.DefaultName).AuthenticationPaths.LogInPath);
    }

    private async Task BeginSignOut(MouseEventArgs args)
    {
        await this.Telemetry.TrackEventAsync("SignedOut");
        await this.Telemetry.FlushAsync();
        this.Navigation.NavigateToLogout(this.OptionsSnapshot.Get(Options.DefaultName).AuthenticationPaths.LogOutPath);
    }

    private async Task GoToMyApps()
    {
        try
        {
            await this.JS.InvokeVoidAsync("safeexchange.closeUserDropdown");
        }
        catch
        {
        }
        this.Navigation.NavigateTo("s2sapps");
    }

    private sealed record VersionInfo(string Version, string BuildDate);
}
