@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Microsoft.Extensions.Options
@using SafeExchange.Client.Web.Components
@using SafeExchange.Client.Web.Components.Helpers
@using System.Reflection

@inject NavigationManager Navigation
@inject IOptionsSnapshot<RemoteAuthenticationOptions<ApiAuthorizationProviderOptions>> OptionsSnapshot
@inject ClipboardService Clipboard
@inject TelemetryService Telemetry
@inject TooltipsInitializer TooltipsInitializerInstance

<AuthorizeView>
    <Authorized>
        <a class="nav-link" href="" @onclick:preventDefault id="userInfoDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-haspopup="true" aria-expanded="false">
            <img src="signed-in.svg" alt="User Info" width="32">
        </a>
        <div class="dropdown-menu" aria-labelledby="userInfoDropdown">
            <form class="px-4 py-2">
                <div class="form-group mb-3">
                    <div>@context.User.Identity.Name</div>
                    <small>@TokenHandler.GetName(context.User)</small>
                </div>
                <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#settingsDialog"><i class="bi bi-gear"></i><span>&nbsp; Settings</span></button>
            </form>
            <div class="dropdown-divider"></div>
            <div class="px-4 py-2 d-flex align-items-center gap-2">
                <small class="text-muted text-nowrap">Session</small>
                @if (this.Telemetry.IsEnabled)
                {
                    <code @ref="this.sessionIdRef" class="flex-grow-1 text-truncate" data-bs-toggle="tooltip" data-bs-placement="top" title="@this.Telemetry.SessionOperationId">@this.TruncatedSessionId</code>
                    <button @ref="this.copyButtonRef" type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="tooltip" data-bs-placement="top" title="Copy to clipboard" aria-label="Copy session id" @onclick="this.CopySessionIdAsync">
                        <i class="bi bi-clipboard"></i>
                    </button>
                }
                else
                {
                    <small class="text-muted fst-italic flex-grow-1">...</small>
                }
            </div>
            <div class="dropdown-divider"></div>
            <div class="px-4 py-2 d-flex align-items-center gap-2">
                <small class="text-muted text-nowrap">Version</small>
                <code class="flex-grow-1 text-truncate" title="@ClientVersion">@ClientVersion</code>
            </div>
            <div class="dropdown-divider"></div>
            <div class="px-4">
                <button class="nav-link btn btn-link" @onclick="BeginSignOut">Sign out</button>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="nav-link" href="" @onclick="@BeginSignIn" @onclick:preventDefault>
            <img src="sign-in.svg" alt="Sign In" width="32">
        </a>
    </NotAuthorized>
</AuthorizeView>

@implements IDisposable

@code{
    // Stamped at build time by the StampClientVersion target in SafeExchange.PWA.csproj
    // (git short SHA + UTC build date), so this reflects exactly what's deployed.
    private static readonly string ClientVersion =
        Assembly.GetExecutingAssembly()
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
        ?? "unknown";

    private ElementReference copyButtonRef;
    private ElementReference sessionIdRef;

    private string TruncatedSessionId
    {
        get
        {
            var id = this.Telemetry.SessionOperationId;
            return id.Length > 8 ? $"{id.Substring(0, 8)}..." : id;
        }
    }

    protected override void OnInitialized()
    {
        // Re-render when the telemetry SDK flips to initialised so the
        // session-id section and its tooltips appear without waiting
        // for the user's next unrelated action.
        this.Telemetry.StateChanged += this.OnTelemetryStateChanged;
    }

    public void Dispose()
    {
        this.Telemetry.StateChanged -= this.OnTelemetryStateChanged;
    }

    private void OnTelemetryStateChanged(object? sender, EventArgs e)
    {
        _ = this.InvokeAsync(this.StateHasChanged);
    }

    private void BeginSignIn(MouseEventArgs args)
    {
        Navigation.NavigateToLogin(OptionsSnapshot.Get(Options.DefaultName).AuthenticationPaths.LogInPath);
    }

    private async Task BeginSignOut(MouseEventArgs args)
    {
        // Emit + flush before navigating — the page unloads almost
        // immediately after, so without a flush the event often never
        // leaves the browser.
        await this.Telemetry.TrackEventAsync("SignedOut");
        await this.Telemetry.FlushAsync();
        Navigation.NavigateToLogout(OptionsSnapshot.Get(Options.DefaultName).AuthenticationPaths.LogOutPath);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Both tooltips only have DOM refs once TelemetryService has
        // returned IsEnabled true (authenticated + backend config
        // fetched). The init helpers are idempotent — safe to call on
        // every render.
        if (this.Telemetry.IsEnabled)
        {
            await this.TooltipsInitializerInstance.InitializeSingleTooltipAsync(this.copyButtonRef, "Copy to clipboard", "Copied");
            await this.TooltipsInitializerInstance.InitializePlainTooltipAsync(this.sessionIdRef);
        }
    }

    private async Task CopySessionIdAsync()
    {
        await this.Clipboard.WriteTextAsync(this.Telemetry.SessionOperationId);
    }
}
