@page "/s2sapps/{DisplayName}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using SafeExchange.Client.Common
@using SafeExchange.Client.Common.Model
@using SafeExchange.Client.Web.Components
@using SafeExchange.Client.Web.Components.Model
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

@inject ApiClient apiClient
@inject StateContainer StateContainer
@inject NavigationManager NavManager

<ItemSearchDialog TItem="GraphUserOutput" @ref="this.userPickDialog" DialogTitle="Find user" Placeholder="Search users..."
                  OnItemPickedCallback="this.FinishUserPick"
                  SearchItemsAsyncCallback="this.SearchUsersAsync"
                  OnClosedCallback="() => this.StateHasChanged()">
    <ItemTemplate Context="user">
        <div class="px-2">
            <div class="text-truncate">@user.DisplayName</div>
            <div class="text-truncate"><small>@user.UserPrincipalName</small></div>
        </div>
    </ItemTemplate>
</ItemSearchDialog>

<ItemSearchDialog TItem="GraphGroupOutput" @ref="this.groupPickDialog" DialogTitle="Find group" Placeholder="Search groups..."
                  OnItemPickedCallback="this.FinishGroupPick"
                  SearchItemsAsyncCallback="this.SearchGroupsAsync"
                  OnClosedCallback="() => this.StateHasChanged()">
    <ItemTemplate Context="group">
        <div class="px-2">
            <div class="text-truncate">@group.DisplayName</div>
            <div class="text-truncate"><small>@(group.Mail ?? "- no mail -")</small></div>
        </div>
    </ItemTemplate>
</ItemSearchDialog>

<div class="d-flex justify-content-end mb-2">
    <button type="button" class="btn btn-outline-secondary" @onclick="this.GoToList">
        <i class="bi bi-arrow-left me-1"></i> Back to list
    </button>
</div>

@if (!string.IsNullOrEmpty(this.error))
{
    <div class="alert alert-warning" role="alert">@this.error</div>
}

@if (this.app is not null)
{
    <dl class="row">
        <dt class="col-sm-3">Entra client id</dt>
        <dd class="col-sm-9"><code>@this.app.AadClientId</code></dd>
        <dt class="col-sm-3">Tenant id</dt>
        <dd class="col-sm-9"><code>@this.app.AadTenantId</code></dd>
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            <span class="badge @(this.app.Enabled ? "text-bg-success" : "text-bg-secondary")">
                @(this.app.Enabled ? "enabled" : "disabled")
            </span>
        </dd>
    </dl>

    <h4 class="mt-3 mb-2">
        <i class="bi bi-people me-1"></i> Owners
        <small class="text-muted ms-2">(@this.app.Owners.Count)</small>
    </h4>

    <ul class="list-group mb-3">
        @foreach (var o in this.app.Owners)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi @(o.SubjectType == OwnerSubjectType.User ? "bi-person" : "bi-people")"></i>
                    <div>
                        <div>@o.SubjectId</div>
                        <small class="text-muted">@o.SubjectType · added @o.AddedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-danger"
                        disabled="@(this.busyOwnerKey == OwnerKey(o))"
                        @onclick="() => this.RemoveOwnerAsync(o)">
                    @if (this.busyOwnerKey == OwnerKey(o)) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                    <i class="bi bi-x-lg me-1"></i> Remove
                </button>
            </li>
        }
    </ul>

    <p class="mt-3 mb-2"><strong>Add a co-owner</strong></p>
    <div class="input-group mb-3">
        <select class="form-select flex-grow-0" style="width: 7rem"
                value="@this.addType"
                @onchange="@(e => this.OnAddTypeChanged(e.Value?.ToString()))">
            <option value="@OwnerSubjectType.User">User</option>
            <option value="@OwnerSubjectType.Group">Group</option>
        </select>
        <input type="text" class="form-control" readonly value="@this.addLabel"
               placeholder="@(this.addType == OwnerSubjectType.User ? "Pick a user" : "Pick a group")" />
        @if (!string.IsNullOrEmpty(this.addSubjectId))
        {
            <button type="button" class="btn btn-outline-secondary" title="Clear" @onclick="this.ClearAdd">
                <i class="bi bi-x-lg"></i>
            </button>
        }
        <button type="button" class="btn btn-outline-primary" @onclick="this.StartAddPickAsync">
            <i class="bi bi-search me-1"></i> Search
        </button>
        <button type="button" class="btn btn-primary"
                disabled="@(string.IsNullOrEmpty(this.addSubjectId) || this.adding)"
                @onclick="this.AddOwnerAsync">
            @if (this.adding) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
            <i class="bi bi-plus-lg me-1"></i> Add
        </button>
    </div>

    <hr />

    <h5 class="text-danger"><i class="bi bi-exclamation-octagon me-1"></i> Danger zone</h5>
    <p class="text-muted">Deleting the app removes it from SafeExchange and cascades all owner rows. This cannot be undone.</p>
    <button type="button" class="btn btn-outline-danger"
            disabled="@this.deleting"
            @onclick="this.DeleteAppAsync">
        @if (this.deleting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
        <i class="bi bi-trash me-1"></i> Delete app
    </button>
}

@code {
    [Parameter] public string DisplayName { get; set; } = string.Empty;

    private S2SApp? app;
    private bool adding;
    private bool deleting;
    private string? busyOwnerKey;
    private string? error;

    private OwnerSubjectType addType = OwnerSubjectType.User;
    private string addSubjectId = string.Empty;
    private string addLabel = string.Empty;

    private ItemSearchDialog<GraphUserOutput>? userPickDialog;
    private ItemSearchDialog<GraphGroupOutput>? groupPickDialog;

    protected override async Task OnInitializedAsync()
    {
        this.StateContainer.SetCurrentPageHeader($"App {this.DisplayName}");
        await this.FetchAsync();
    }

    private async Task FetchAsync()
    {
        this.StateContainer.IsInProgress = true;
        this.error = null;
        try
        {
            var response = await this.apiClient.GetS2SAppAsync(this.DisplayName);
            if ("ok".Equals(response.Status))
            {
                this.app = response.Result;
                this.StateContainer.SetCurrentPageHeader($"App {this.app?.DisplayName ?? this.DisplayName}");
            }
            else if ("disabled".Equals(response.Status))
            {
                this.error = "Self-service S2S app registration is disabled in this environment.";
            }
            else
            {
                this.error = response.Error ?? response.Status;
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        finally
        {
            this.StateContainer.IsInProgress = false;
        }
    }

    private static string OwnerKey(S2SAppOwner o) => $"{o.SubjectType}|{o.SubjectId}";

    private void OnAddTypeChanged(string? newValue)
    {
        if (Enum.TryParse<OwnerSubjectType>(newValue, out var t) && t != this.addType)
        {
            this.addType = t;
            this.ClearAdd();
        }
    }

    private void ClearAdd()
    {
        this.addSubjectId = string.Empty;
        this.addLabel = string.Empty;
    }

    private async Task StartAddPickAsync()
    {
        if (this.addType == OwnerSubjectType.User)
        {
            if (this.userPickDialog is not null)
            {
                await this.userPickDialog.StartItemSearchAsync();
            }
        }
        else
        {
            if (this.groupPickDialog is not null)
            {
                await this.groupPickDialog.StartItemSearchAsync();
            }
        }
    }

    private async Task<BaseResponseObject<List<GraphUserOutput>>> SearchUsersAsync(SearchInput searchInput)
        => await this.apiClient.SearchUsersAsync(searchInput);

    private async Task<BaseResponseObject<List<GraphGroupOutput>>> SearchGroupsAsync(SearchInput searchInput)
        => await this.apiClient.SearchGroupsAsync(searchInput);

    public void FinishUserPick(GraphUserOutput pickedUser)
    {
        this.addType = OwnerSubjectType.User;
        this.addSubjectId = pickedUser.UserPrincipalName ?? string.Empty;
        this.addLabel = string.IsNullOrEmpty(pickedUser.DisplayName)
            ? (pickedUser.UserPrincipalName ?? string.Empty)
            : $"{pickedUser.DisplayName} ({pickedUser.UserPrincipalName})";
    }

    public void FinishGroupPick(GraphGroupOutput pickedGroup)
    {
        this.addType = OwnerSubjectType.Group;
        this.addSubjectId = pickedGroup.Id ?? string.Empty;
        this.addLabel = string.IsNullOrEmpty(pickedGroup.DisplayName)
            ? (pickedGroup.Id ?? string.Empty)
            : pickedGroup.DisplayName;
    }

    private async Task AddOwnerAsync()
    {
        if (string.IsNullOrEmpty(this.addSubjectId) || this.app is null) { return; }
        this.adding = true;
        this.error = null;
        try
        {
            var input = new S2SAppOwnerInput { SubjectType = this.addType, SubjectId = this.addSubjectId.Trim() };
            var response = await this.apiClient.AddS2SAppOwnerAsync(this.app.DisplayName, input);
            if ("ok".Equals(response.Status))
            {
                this.ClearAdd();
                await this.FetchAsync();
            }
            else
            {
                this.error = response.Error ?? response.Status;
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        finally
        {
            this.adding = false;
        }
    }

    private async Task RemoveOwnerAsync(S2SAppOwner owner)
    {
        if (this.app is null) { return; }
        this.busyOwnerKey = OwnerKey(owner);
        this.error = null;
        try
        {
            var response = await this.apiClient.RemoveS2SAppOwnerAsync(this.app.DisplayName, owner.SubjectType, owner.SubjectId);
            if ("ok".Equals(response.Status))
            {
                await this.FetchAsync();
            }
            else
            {
                this.error = response.Error ?? response.Status;
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        finally
        {
            this.busyOwnerKey = null;
        }
    }

    private async Task DeleteAppAsync()
    {
        if (this.app is null) { return; }
        this.deleting = true;
        this.error = null;
        try
        {
            var response = await this.apiClient.DeleteS2SAppAsync(this.app.DisplayName);
            if ("ok".Equals(response.Status))
            {
                this.NavManager.NavigateTo("s2sapps");
            }
            else
            {
                this.error = response.Error ?? response.Status;
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        finally
        {
            this.deleting = false;
        }
    }

    private void GoToList() => this.NavManager.NavigateTo("s2sapps");
}
