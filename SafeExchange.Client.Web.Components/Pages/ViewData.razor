@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop;
@using SafeExchange.Client.Common
@using SafeExchange.Client.Common.Model
@using SafeExchange.Client.Web.Components.Model
@using SafeExchange.Client.Web.Components.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text
@using System.IO

@inject NavigationManager NavManager
@inject ApiClient apiClient
@inject StateContainer StateContainer
@inject TooltipsInitializer TooltipsInitializerInstance
@inject DownloadUploadHelper downloadUploadHelper
@inject VerifiedDownloadHelper VerifiedDownload
@inject LocalFileVerifier LocalFileVerifier
@inject ClipboardService Clipboard
@inject IJSRuntime JSRuntime
@inject IOptionsSnapshot<RemoteAuthenticationOptions<ApiAuthorizationProviderOptions>> OptionsSnapshot
@inject IConfiguration Configuration
@inject TelemetryService Telemetry

@if (this.Notification != null)
{
    <div class="alert alert-dismissible @(this.Notification.GetAlertClass() ?? "alert-primary")" role="alert">
        <p>
            <strong>@(this.Notification.Status ?? string.Empty)</strong>&nbsp; @(this.Notification.Message ?? string.Empty)
        </p>
        @if (!string.IsNullOrEmpty(this.Notification.ButtonText))
        {
            <hr>
            <p>
                <button class="btn btn-warning" type="button" disabled="@this.StateContainer.IsInProgress" @onclick="() => this.HandleNotificationButtonClick()">
                    <span>@this.Notification.ButtonText</span>
                </button>
            </p>
        }
        <button type="button" class="btn-close" @onclick="DismissNotification" aria-label="Close"></button>
    </div>
}

@if (this.compoundModel != null)
{
    <EditForm Model="@this.compoundModel">
        <p>
            <div class="ql-container ql-snow">
                <div @ref="this.quillElement" id="main_content" class="ql-editor @(this.StateContainer.IsInProgress ? "ql-blank" : string.Empty)" data-placeholder="Loading...">
                    @if (!this.StateContainer.IsInProgress)
                    {
                        @((MarkupString)MainDataSanitizer.Sanitize(this.compoundModel.MainData))
                    }
                </div>
            </div>
        </p>

        @if (this.Attachments.Count > 0)
        {
            <p>
                <div class="collapsible-content">
                    <button class="btn mb-2 d-inline-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAttachments" aria-expanded="false" aria-controls="collapseAttachments">
                        <i class="bi bi-chevron-right"></i>
                        &nbsp; Attachments
                    </button>
                    <div class="collapse" id="collapseAttachments">
                        <div class="card card-body">

                            <ul class="list-group list-group-flush">
                                @for (int ai = 0; ai < this.Attachments.Count; ai++)
                                {
                                    var attachment = this.Attachments[ai];
                                    var downloadItem = this.Downloads[ai];
                                    <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap">
                                        <div class="d-flex align-items-center flex-wrap">
                                            <span id="@($"attachment-{ai}")">@attachment.FileName</span>
                                            <small class="my-0">&nbsp;&nbsp; Size: @attachment.GetLengthDescription()</small>
                                            @if (!string.IsNullOrEmpty(attachment.Hash))
                                            {
                                                <code class="ms-3 me-1" data-bs-toggle="tooltip" data-bs-placement="top" title="@attachment.Hash">@TruncateHash(attachment.Hash)</code>
                                                <button type="button" class="btn btn-sm btn-link p-0 me-2"
                                                        @onclick="@(async () => await this.Clipboard.WriteTextAsync(attachment.Hash ?? string.Empty))"
                                                        data-bs-toggle="tooltip" data-bs-placement="top" title="Copy hash">
                                                    <i class="bi bi-clipboard"></i>
                                                </button>
                                            }
                                        </div>
                                        <div class="d-flex align-items-center">
                                            @if (downloadItem.Status == DownloadStatus.InProgress)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                <span class="me-2">@FormatPercent(downloadItem.ProgressPercents)</span>
                                            }
                                            else
                                            {
                                                @switch (this.ResolveBadge(attachment, downloadItem.Status))
                                                {
                                                    case AttachmentBadgeKind.Verified:
                                                        <i class="bi bi-shield-fill-check text-success me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Integrity verified on download."></i>
                                                        break;
                                                    case AttachmentBadgeKind.Failed:
                                                        <i class="bi bi-exclamation-diamond text-danger me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Last download failed the integrity check. The file on disk may be partial or corrupt."></i>
                                                        break;
                                                    case AttachmentBadgeKind.Legacy:
                                                        <i class="bi bi-question-diamond text-secondary me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Uploaded before the integrity feature — no reference hash is stored. Re-upload this attachment to enable verification."></i>
                                                        break;
                                                    case AttachmentBadgeKind.LegacySuccess:
                                                        <i class="bi bi-check-lg text-success me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Download complete."></i>
                                                        break;
                                                    case AttachmentBadgeKind.LegacyError:
                                                        <i class="bi bi-exclamation-triangle text-warning me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Download failed."></i>
                                                        break;
                                                }
                                            }
                                            <button class="btn btn-outline-primary" type="button" disabled="@(this.StateContainer.IsInProgress || DownloadStatus.InProgress.Equals(downloadItem.Status))" @onclick="@(e => this.DownloadAttachmentAsync(attachment))">
                                                <i class="bi bi-cloud-download"></i><span>&nbsp;Download</span>
                                            </button>
                                            <div class="dropdown d-inline-block ms-1">
                                                <button type="button" class="btn btn-sm btn-link" data-bs-toggle="dropdown" aria-expanded="false" aria-label="More actions">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li>
                                                        <button type="button"
                                                                class="dropdown-item @(string.IsNullOrEmpty(attachment.Hash) ? "disabled" : string.Empty)"
                                                                disabled="@string.IsNullOrEmpty(attachment.Hash)"
                                                                @onclick="@(async () => await this.TriggerLocalVerifyClickAsync(attachment))">
                                                            Verify local file…
                                                        </button>
                                                    </li>
                                                </ul>
                                            </div>
                                            <InputFile id="@($"verifyInput-{attachment.ContentName}")" style="display:none"
                                                       OnChange="@(async e => await this.RunLocalVerifyAsync(attachment, e))" />
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </p>
        }

        <div class="collapsible-content">
            <button class="btn mb-2 d-inline-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAccessList" aria-expanded="false" aria-controls="collapseAccessList">
                <i class="bi bi-chevron-right"></i>
                &nbsp; Access List
            </button>
            <div class="collapse" id="collapseAccessList">
                <div class="card card-body">

                    @{
                        int i = 0;
                    }
                    @foreach (var permissionsItem in this.compoundModel.Permissions)
                    {
                        <div>
                            <div class="row">
                                <div class="col">
                                    <InputText id="@($"username-{i}")" class="form-control-plaintext" @bind-Value="@permissionsItem.SubjectName" readonly />
                                </div>
                                <div class="col">
                                    <InputText id="@($"permissions-{i}")" class="form-control-plaintext" @bind-Value="@permissionsItem.PermissionsString" readonly aria-label="Permissions" aria-labelledby="@($"permissions-{i} username-{i}")" />
                                </div>
                            </div>
                        </div>
                        i += 1;
                    }

                    @if (this.compoundModel.Permissions.Count == 0)
                    {
                        <div>
                            - No access was granted to users -
                        </div>
                    }

                </div>
            </div>
        </div>

        <p>
            <div class="d-flex mt-3 justify-content-center">
                <div class="btn-group" role="group" aria-label="Item buttons">
                    <button class="btn btn-outline-primary" type="button" disabled="@this.StateContainer.IsInProgress" @onclick="FetchData">
                        @if (this.StateContainer.IsInProgress)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        }
                        else
                        {
                            <i class="bi bi-arrow-clockwise"></i>
                        }
                        <span>&nbsp;Refresh</span>
                    </button>
                    <button class="btn btn-outline-primary" type="button" disabled="@(!this.CanEditObject() || this.StateContainer.IsInProgress)" @onclick="EditObject">
                        <i class="bi bi-pencil"></i><span>&nbsp;Edit</span>
                    </button>
                </div>
            </div>
        </p>
    </EditForm>
}

@if (this.integrityFailure.HasValue)
{
    <div class="modal d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.4);">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-diamond"></i>&nbsp; Integrity check failed</h5>
                </div>
                <div class="modal-body">
                    <p>The download of <strong>@this.integrityFailure.Value.content.FileName</strong> could not be verified against the reference hash stored with this attachment.</p>
                    <p class="text-muted small">The file at the chosen location may be partial or corrupt — please delete it.</p>
                    @if (this.integrityFailure.Value.result.FailedAtChunk.HasValue && this.integrityFailure.Value.result.FailedAtChunk.Value >= 0)
                    {
                        <p class="text-muted small">Failed at chunk @(this.integrityFailure.Value.result.FailedAtChunk.Value + 1)/@this.integrityFailure.Value.result.ChunkCount.</p>
                    }
                    @if (!string.IsNullOrEmpty(this.integrityFailure.Value.result.Error))
                    {
                        <p class="text-muted small font-monospace">@this.integrityFailure.Value.result.Error</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="@(() => this.integrityFailure = null)">Dismiss</button>
                </div>
            </div>
        </div>
    </div>
}

@if (this.localVerifyMessage is not null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;">
        <div class="toast show @(this.localVerifySuccess ? "bg-success" : "bg-danger") text-white">
            <div class="toast-body d-flex justify-content-between align-items-center">
                <span>@this.localVerifyMessage</span>
                <button type="button" class="btn-close btn-close-white ms-2" @onclick="@(() => this.localVerifyMessage = null)"></button>
            </div>
        </div>
    </div>
}

@code {

    [CascadingParameter]
    public Task<AuthenticationState> AuthenticationStateTask { get; set; }

    [Parameter]
    public string ObjectName { get; set; }

    private AuthenticationState authenticationState;

    private NotificationData Notification;

    private ElementReference quillElement;

    private bool initializeTooltips = false;

    private CompoundModel compoundModel = new CompoundModel()
        {
            Metadata = new ObjectMetadata()
            {
                ObjectName = string.Empty,
                Content = new List<ContentMetadata>(),
                ExpirationMetadata = new ExpirationMetadata()
                {
                    ScheduleExpiration = false,
                    ExpireAt = DateTime.MinValue,
                    ExpireOnIdleTime = false,
                    IdleTimeToExpire = TimeSpan.Zero
                }
            },
            Permissions = new List<SubjectPermissions>()
        {
            new SubjectPermissions()
            {
                ObjectName = string.Empty,
                SubjectName = string.Empty,
                SubjectId = string.Empty,

                CanRead = true,
                CanWrite = false,
                CanGrantAccess = false,
                CanRevokeAccess = false
            }
        },
            MainData = string.Empty
        };

    private List<ContentMetadata> Attachments { get; set; } = new();

    private List<DownloadModel> Downloads { get; set; } = new();

    // All states the single right-cluster badge can be in. The download-in-progress
    // case is handled separately (spinner + percent) — this enum covers what the
    // user sees at rest. The Legacy* variants exist only when content has no
    // reference hash, so the badge doubles as the download-result indicator.
    private enum AttachmentBadgeKind { None, Verified, Failed, Legacy, LegacySuccess, LegacyError }

    private enum AttachmentVerifyResult { Success, Failure }

    private readonly Dictionary<string, AttachmentVerifyResult> lastVerifyResults = new();

    private static string TruncateHash(string? hash)
    {
        if (string.IsNullOrEmpty(hash))
        {
            return string.Empty;
        }

        return hash.Length > 8 ? hash.Substring(0, 8) + "…" : hash;
    }

    // Floats come out of the upload loop with decimals. Display with one decimal
    // ("47.3%") and collapse an exact zero to "0%" so rows that haven't been
    // touched aren't visually noisy.
    private static string FormatPercent(float percent)
    {
        if (percent <= 0)
        {
            return "0%";
        }

        return $"{percent:0.0}%";
    }

    private AttachmentBadgeKind ResolveBadge(ContentMetadata content, DownloadStatus status)
    {
        var isLegacy = string.IsNullOrEmpty(content.Hash);
        if (isLegacy)
        {
            return status switch
            {
                DownloadStatus.Success => AttachmentBadgeKind.LegacySuccess,
                DownloadStatus.Error => AttachmentBadgeKind.LegacyError,
                _ => AttachmentBadgeKind.Legacy,
            };
        }

        if (this.lastVerifyResults.TryGetValue(content.ContentName, out var lastResult))
        {
            return lastResult == AttachmentVerifyResult.Success
                ? AttachmentBadgeKind.Verified
                : AttachmentBadgeKind.Failed;
        }

        return AttachmentBadgeKind.None;
    }

    private string? localVerifyMessage;

    private bool localVerifySuccess;

    private async Task TriggerLocalVerifyClickAsync(ContentMetadata attachment)
    {
        if (string.IsNullOrEmpty(attachment.Hash))
        {
            return;
        }

        await this.JSRuntime.InvokeVoidAsync("eval",
            $"document.getElementById('verifyInput-{attachment.ContentName}').click()");
    }

    private async Task RunLocalVerifyAsync(ContentMetadata attachment, InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        var computed = await this.LocalFileVerifier.ComputeHashAsync(file);
        this.localVerifySuccess = string.Equals(computed, attachment.Hash, StringComparison.OrdinalIgnoreCase);
        this.localVerifyMessage = this.localVerifySuccess
            ? $"\u2713 {file.Name} matches this attachment."
            : $"\u2717 {file.Name} does NOT match. Computed: {(computed.Length > 12 ? computed.Substring(0, 12) + "…" : computed)}";
        await this.Telemetry.TrackEventAsync("AttachmentLocalVerified", new Dictionary<string, string>
        {
            ["attachmentId"] = attachment.ContentName,
            ["result"] = this.localVerifySuccess ? "match" : "mismatch",
        });
        this.StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        this.StateContainer.IsInProgress = false;
        this.StateContainer.TakeNotification();

        this.ObjectName = this.ObjectName ?? string.Empty;
        this.StateContainer.SetCurrentPageHeader($"View '{this.ObjectName}'");

        this.authenticationState = await this.AuthenticationStateTask;
        await this.FetchData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Wire every `[data-bs-toggle="tooltip"]` on the page as a plain
        // hover-only Bootstrap tooltip. The JS helper is idempotent per
        // element (marks DOM nodes after first wiring) so repeat calls
        // on subsequent renders are cheap and only touch new nodes —
        // e.g. the attachment-row integrity badges and the copy-hash
        // button that appear once the secret payload arrives.
        await TooltipsInitializerInstance.InitializeAllPlainTooltipsAsync();

        if (!this.initializeTooltips)
        {
            return;
        }

        try
        {
            await TooltipsInitializerInstance.InitializeQuillClipboardTooltipsAsync(this.quillElement, "Copy to clipboard", "Copied");
        }
        finally
        {
            this.initializeTooltips = false;
        }
    }

    private async Task FetchData()
    {
        await this.FetchSecretAsync(this.ObjectName);
    }

    private bool CanEditObject()
    {
        var currentUserUpn = TokenHandler.GetName(authenticationState.User);
        if (string.IsNullOrEmpty(currentUserUpn) || !currentUserUpn.Contains("@"))
        {
            return true;
        }

        var accessList = this.compoundModel?.Permissions;
        if (accessList == null)
        {
            return false;
        }

        foreach (var accessItem in accessList)
        {
            if (accessItem.SubjectName.Equals(currentUserUpn) && (accessItem.CanWrite || accessItem.CanGrantAccess))
            {
                return true;
            }
        }

        return false;
    }

    private void EditObject()
    {
        NavManager.NavigateTo($"editdata/{this.ObjectName}");
    }

    private async Task FetchSecretAsync(string objectName)
    {
        this.StateContainer.IsInProgress = true;
        try
        {
            var compoundModelResult = await this.apiClient.GetCompoundModelAsync(objectName);
            if (!"ok".Equals(compoundModelResult.Status))
            {
                var consentRequired = false;
                var message = compoundModelResult.Error ?? string.Empty;
                var buttonText = "forbidden".Equals(compoundModelResult.Status) ? "Request Access" : string.Empty;
                if ("consent_required".Equals(compoundModelResult.SubStatus))
                {
                    consentRequired = true;
                    message = "User must give consent in Entra to fetch groups in order to use groups authorization.";
                    buttonText = "Consent";
                }

                this.Notification = new NotificationData()
                    {
                        Type = NotificationType.Warning,
                        Status = compoundModelResult.Status,
                        Message = message,
                        ButtonText = buttonText,
                        ButtonUri = this.CreateAccessRequestUri("Read"),
                        ConsentRequired = consentRequired
                    };

                return;
            }

            this.DismissNotification();

            this.Attachments = new(compoundModelResult.Result.Metadata.Content.Where(c => !c.IsMain));
            this.Downloads.Clear();
            foreach (var attachment in this.Attachments)
            {
                this.Downloads.Add(new DownloadModel(attachment));
            }

            this.compoundModel.Metadata = compoundModelResult.Result.Metadata;
            this.compoundModel.Permissions = compoundModelResult.Result.Permissions;
            this.compoundModel.MainData = compoundModelResult.Result.MainData;

            this.initializeTooltips = true;

            await this.Telemetry.TrackEventAsync("ReadSecret", new Dictionary<string, string>
            {
                ["name"] = objectName
            });
        }
        catch (AccessTokenNotAvailableException exception)
        {
            exception.Redirect();
        }
        finally
        {
            this.StateContainer.IsInProgress = false;
        }
    }

    public void DismissNotification()
    {
        this.Notification = null;
    }

    private string CreateAccessRequestUri(string permissions)
    {
        return $"addrequest?subject={this.ObjectName}&permission={permissions}";
    }

    private (ContentMetadata content, VerifiedDownloadResult result)? integrityFailure;

    private async Task DownloadAttachmentAsync(ContentMetadata attachment)
    {
        // Legacy attachments (no reference hash) fall back to the pre-integrity flow.
        if (string.IsNullOrEmpty(attachment.Hash))
        {
            await this.LegacyDownloadAsync(attachment);
            return;
        }

        var downloadItem = this.Downloads.First(d => d.Attachment.Equals(attachment));
        try
        {
            downloadItem.Status = DownloadStatus.InProgress;
            downloadItem.ProgressPercents = 0.0f;
            this.StateHasChanged();

            var result = await this.VerifiedDownload.DownloadAsync(
                this.compoundModel.Metadata.ObjectName,
                attachment);

            if (result.IsSuccess)
            {
                this.lastVerifyResults[attachment.ContentName] = AttachmentVerifyResult.Success;
                downloadItem.Status = DownloadStatus.Success;
                downloadItem.ProgressPercents = 100.0f;
                await this.Telemetry.TrackEventAsync("AttachmentVerified", new Dictionary<string, string>
                {
                    ["attachmentId"] = attachment.ContentName,
                    ["sizeBucket"] = SizeBucket(this.TotalAttachmentBytes(attachment)),
                });
            }
            else
            {
                this.lastVerifyResults[attachment.ContentName] = AttachmentVerifyResult.Failure;
                this.integrityFailure = (attachment, result);
                downloadItem.Status = DownloadStatus.Error;
                await this.Telemetry.TrackEventAsync("AttachmentVerifyFailed", new Dictionary<string, string>
                {
                    ["attachmentId"] = attachment.ContentName,
                    ["sizeBucket"] = SizeBucket(this.TotalAttachmentBytes(attachment)),
                    ["failedAt"] = result.FailedAtChunk.HasValue && result.FailedAtChunk.Value >= 0
                        ? $"chunk:{result.FailedAtChunk.Value}"
                        : "wholeContent",
                });
            }
        }
        catch (Exception ex)
        {
            this.lastVerifyResults[attachment.ContentName] = AttachmentVerifyResult.Failure;
            this.integrityFailure = (attachment, VerifiedDownloadResult.Failed(-1, attachment.Chunks.Count, ex.Message));
            downloadItem.Status = DownloadStatus.Error;
            await this.Telemetry.TrackEventAsync("AttachmentVerifyFailed", new Dictionary<string, string>
            {
                ["attachmentId"] = attachment.ContentName,
                ["sizeBucket"] = SizeBucket(this.TotalAttachmentBytes(attachment)),
                ["failedAt"] = "exception",
            });
        }
        finally
        {
            this.StateHasChanged();
        }
    }

    private static string SizeBucket(long bytes)
    {
        if (bytes < 1L * 1024 * 1024)
        {
            return "<1M";
        }
        if (bytes < 10L * 1024 * 1024)
        {
            return "1-10M";
        }
        if (bytes < 100L * 1024 * 1024)
        {
            return "10-100M";
        }
        return ">100M";
    }

    private long TotalAttachmentBytes(ContentMetadata attachment)
    {
        var total = 0L;
        foreach (var chunk in attachment.Chunks)
        {
            total += chunk.Length;
        }
        return total;
    }

    private async Task LegacyDownloadAsync(ContentMetadata attachment)
    {
        var downloadItem = this.Downloads.First(d => d.Attachment.Equals(attachment));
        try
        {
            if (await this.downloadUploadHelper.SupportsFileSystemAccessAsync())
            {
                await DownloadToFileStreamAsync(attachment, downloadItem);
                return;
            }

            await DownloadAsBlobUrlAsync(attachment, downloadItem);
        }
        finally
        {
            if (downloadItem.Status == DownloadStatus.InProgress)
            {
                downloadItem.Status = DownloadStatus.Success;
            }

            this.StateHasChanged();
        }
    }

    private async Task DownloadToFileStreamAsync(ContentMetadata attachment, DownloadModel downloadItem)
    {
        Console.WriteLine($"Started {nameof(DownloadToFileStreamAsync)}.");

        IJSObjectReference? writableStream = default;
        try
        {
            writableStream = await this.downloadUploadHelper.StartFileDownloadAsync(attachment.FileName);
            if (writableStream == null)
            {
                return; // user aborted file download
            }

            downloadItem.Status = DownloadStatus.InProgress;
            downloadItem.ProgressPercents = 0.0f;
            this.StateHasChanged();

            var totalLength = 0L;
            foreach (var chunk in attachment.Chunks)
            {
                totalLength += chunk.Length;
            }

            foreach (var chunk in attachment.Chunks)
            {
                var chunkStreamResponse = await this.apiClient.GetSecretDataStreamAsync(this.compoundModel.Metadata.ObjectName, attachment.ContentName, chunk.ChunkName);
                if (!"ok".Equals(chunkStreamResponse.Status))
                {
                    this.Notification = new NotificationData()
                        {
                            Type = NotificationType.Warning,
                            Status = chunkStreamResponse.Status,
                            Message = $"Cannot download attachment: {(chunkStreamResponse.Error ?? "Unknown exception.")}."
                        };

                    downloadItem.Status = DownloadStatus.Error;
                    return;
                }

                if (chunkStreamResponse.Result is null)
                {
                    this.Notification = new NotificationData()
                        {
                            Type = NotificationType.Warning,
                            Status = chunkStreamResponse.Status,
                            Message = $"Received empty data reponse ('{chunk.ChunkName}'."
                        };

                    downloadItem.Status = DownloadStatus.Error;
                    return;
                }

                await this.downloadUploadHelper.WriteToFileAsync(writableStream, chunkStreamResponse.Result);

                downloadItem.ProgressPercents += 100.0f * ((float)chunk.Length / (totalLength == 0 ? 1 : totalLength));
                this.StateHasChanged();
            }
        }
        catch (Exception exception)
        {
            this.Notification = new NotificationData()
                {
                    Type = NotificationType.Warning,
                    Status = string.Empty,
                    Message = exception.Message
                };
        }
        finally
        {
            if (writableStream != default)
            {
                await this.downloadUploadHelper.FinishFileDownloadAsync(writableStream);
            }
        }
    }

    private async Task DownloadAsBlobUrlAsync(ContentMetadata attachment, DownloadModel downloadItem)
    {
        Console.WriteLine($"Started {nameof(DownloadAsBlobUrlAsync)}.");

        downloadItem.Status = DownloadStatus.InProgress;
        downloadItem.ProgressPercents = 0.0f;
        this.StateHasChanged();

        var dataStreamResponse = await this.apiClient.GetContentDataStreamAsync(this.compoundModel.Metadata.ObjectName, attachment.ContentName);
        if (dataStreamResponse.Status != "ok")
        {
            this.Notification = new NotificationData()
                {
                    Type = NotificationType.Warning,
                    Status = dataStreamResponse.Status,
                    Message = $"Cannot download attachment: {(dataStreamResponse.Error ?? "Unknown exception.")}."
                };

            return;
        }

        if (dataStreamResponse.Result is null)
        {
            this.Notification = new NotificationData()
                {
                    Type = NotificationType.Warning,
                    Status = dataStreamResponse.Status,
                    Message = $"Received empty data reponse."
                };

            return;
        }

        await this.downloadUploadHelper.DownloadFileFromStreamAsync(dataStreamResponse.Result, attachment.FileName, attachment.ContentType);
    }

    private void HandleNotificationButtonClick()
    {
        if (this.Notification.ConsentRequired)
        {
            var scopesToConsent = new List<string>();
            this.Configuration.Bind("AdditionalScopesToConsent", scopesToConsent);
            var requestOptions = new InteractiveRequestOptions
                {
                    Interaction = InteractionType.GetToken,
                    ReturnUrl = this.NavManager.Uri,
                    Scopes = scopesToConsent ?? Array.Empty<string>().ToList()
                };

            requestOptions.TryAddAdditionalParameter("prompt", "consent");
            this.NavManager.NavigateToLogin(OptionsSnapshot.Get(Options.DefaultName).AuthenticationPaths.LogInPath, requestOptions);
            return;
        }

        this.NavManager.NavigateTo(this.Notification.ButtonUri);
    }
}

