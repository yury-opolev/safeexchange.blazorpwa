@inject StateContainer StateContainerInstance

@implements IDisposable

@if (this.StateContainerInstance.IsInProgress)
{
<div class="spinner-border spinner-border-sm" role="status">
    <span class="visually-hidden">In progress...</span>
</div>
<span class="mr-2"></span>
}
<span>
    @StateContainerInstance.CurrentPageHeader
</span>
@if (!string.IsNullOrEmpty(this.StateContainerInstance.HeaderBadgeText))
{
    <span class="badge text-bg-info ms-2" title="@this.StateContainerInstance.HeaderBadgeTooltip">
        @if (!string.IsNullOrEmpty(this.StateContainerInstance.HeaderBadgeIcon))
        {
            <i class="bi @this.StateContainerInstance.HeaderBadgeIcon"></i><span>&nbsp;</span>
        }
        @this.StateContainerInstance.HeaderBadgeText
    </span>
}

@code{
    protected override void OnInitialized()
    {
        StateContainerInstance.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        StateContainerInstance.OnChange -= StateHasChanged;
    }
}
